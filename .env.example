# Database Configuration
DB_HOST=your_database_host
DB_USER=your_database_username
DB_PASSWORD=your_secure_password
DB_NAME=your_database_name
DB_PORT=your_database_port

# Server Configuration
PORT=your_preferred_port
NODE_ENV=development     # set to "production" on your hosting platform
JWT_SECRET=your_jwt_secret_key

# Frontend URL — REQUIRED in production to fix Paystack payment redirect
# This must be the root URL of the deployed frontend, e.g. https://rearview.com
# In local dev, leave this blank — the app will auto-detect from CORS_ORIGIN
FRONTEND_URL=https://your-frontend-domain.com
CORS_ORIGIN=http://localhost:3000

# Paystack
# NOTE: Even if you use the same test keys locally and in production,
# FRONTEND_URL is still needed so the callback lands on the correct environment.
# Get your keys from https://dashboard.paystack.com
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx

# Example values:
# DB_HOST=localhost
# DB_USER=root
# DB_PORT=3306
# PORT=4000
# JWT_SECRET=your-256-bit-secret
# FRONTEND_URL=https://rearview.com
